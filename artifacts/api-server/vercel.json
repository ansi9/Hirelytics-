{
  "buildCommand": "pnpm install && pnpm --filter @workspace/resume-shortlister build",
  "outputDirectory": "artifacts/resume-shortlister/dist",
  "env": {
    "VITE_API_BASE_URL": "@api-base-url"
  },
  "routes": [
    {
      "src": "^/(?!.*\\.).*$",
      "destination": "/index.html"
    }
  ]
}
